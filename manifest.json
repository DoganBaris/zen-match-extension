{
  "manifest_version": 3,
  "name": "Zen Match - Tile Puzzle",
  "version": "1.0.0",
  "description": "A relaxing tile matching puzzle game. Match 3 identical tiles to clear them before the bar fills up!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage"]
}
